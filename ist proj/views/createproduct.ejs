<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Create Product</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-200 min-h-screen p-8">

    <div class="max-w-xl mx-auto bg-white/80 backdrop-blur-xl p-10 rounded-2xl shadow-xl border border-gray-300">

        <h1 class="text-3xl font-bold mb-6 text-gray-800">Create Product</h1>

        <form action="/owners/create" method="POST" enctype="multipart/form-data" class="space-y-6">

            <input type="text" name="name"
                   class="w-full p-3 border rounded-lg focus:ring-2 focus:ring-black"
                   placeholder="Product Name">

            <input type="number" name="price"
                   class="w-full p-3 border rounded-lg focus:ring-2 focus:ring-black"
                   placeholder="Price">

            <input type="file" name="image"
                   class="w-full p-3 border rounded-lg bg-white">

            <button class="w-full py-3 bg-black text-white rounded-xl hover:bg-gray-900 transition">
                Create
            </button>

        </form>

    </div>

</body>
</html>
