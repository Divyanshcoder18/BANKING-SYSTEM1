<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Home</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100 flex items-center justify-center min-h-screen">

    <div class="backdrop-blur-xl bg-white/70 p-10 rounded-2xl shadow-xl w-full max-w-md border border-white/40">

        <h1 class="text-3xl font-bold text-center mb-6 text-gray-800">Welcome</h1>

        <% if (error && error.length > 0) { %>
            <p class="text-red-600 text-center mb-4 font-medium"><%= error %></p>
        <% } %>

        <div class="flex flex-col space-y-4 mt-6">
            <a href="/login"
               class="text-center py-3 bg-black text-white rounded-xl hover:bg-gray-800 transition">
                Login
            </a>

            <a href="/register"
               class="text-center py-3 bg-gray-800 text-white rounded-xl hover:bg-black transition">
                Register
            </a>
        </div>

    </div>

</body>
</html>

