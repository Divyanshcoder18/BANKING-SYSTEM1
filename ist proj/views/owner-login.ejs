<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Owner Login</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-200 flex items-center justify-center min-h-screen">

    <div class="bg-white/80 backdrop-blur-xl p-10 rounded-2xl shadow-xl w-full max-w-md border border-gray-300">

        <h1 class="text-2xl font-bold text-center mb-6 text-gray-900">Owner Login</h1>

        <form action="/owners/login" method="POST" class="space-y-6">

            <input type="email" name="email"
                   class="w-full p-3 border rounded-lg focus:outline-none focus:ring-2 focus:ring-black"
                   placeholder="Email">

            <input type="password" name="password"
                   class="w-full p-3 border rounded-lg focus:outline-none focus:ring-2 focus:ring-black"
                   placeholder="Password">

            <button class="w-full py-3 bg-black text-white rounded-xl hover:bg-gray-900 transition">
                Login
            </button>

        </form>

    </div>

</body>
</html>
